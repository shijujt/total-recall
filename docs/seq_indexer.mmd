sequenceDiagram
    participant Script as main_indexer
    participant Indexer as AwsSvcIndexer
    participant Parser as MarkdownSectionParser
    participant QG as LlamaQueryGenerator
    participant Ollama as Ollama API
    participant Chroma as ChromaDB
    participant FS as Filesystem

    Script->>Indexer: __init__(base_docs_path, collection_name)
    alt indexing_mode (collection_name != None)
        Indexer->>Chroma: PersistentClient() + get_or_create_collection()
    else query_gen_mode (collection_name == None)
        Indexer->>QG: __init__()
    end

    Script->>Indexer: index_services(svc_names)

    loop for each service folder
        Indexer->>FS: os.walk(svc_path/doc_source)
        loop for each .md file
            Indexer->>Parser: parse_file(filepath)
            Parser->>FS: open + read file
            alt H2 headings present
                Parser-->>Indexer: chunks split at H2 boundaries
            else bold sections present
                Parser-->>Indexer: chunks split at bold markers
            else no structure
                Parser-->>Indexer: chunks split by token window (400 tokens)
            end

            alt indexing_mode
                Indexer->>Chroma: collection.add(documents, metadatas, ids)
            else query_gen_mode
                Indexer->>QG: generate_queries(chunk_text, service_name)
                QG->>Ollama: POST /api/generate — llama3
                Ollama-->>QG: JSON with 3 developer questions
                QG-->>Indexer: queries[]
                Indexer->>FS: append records to eval_queries_ag.jsonl
            end
        end
    end
